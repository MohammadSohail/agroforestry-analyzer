# ---- API (apps/api) ----
NODE_ENV=development
PORT=3000

# Postgres connection string used by Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/agroforestry?schema=public

# WeatherAI provider selection: "mock" (no key needed) or "live"
WEATHER_AI_MODE=mock
WEATHER_AI_BASE_URL=https://api.weather-ai.co
WEATHER_AI_API_KEY=wai_replace_me
# Per-request timeout (ms) and retry budget for the live HTTP adapter
WEATHER_AI_TIMEOUT_MS=10000
WEATHER_AI_MAX_RETRIES=2

# Local disk storage for uploaded imagery
STORAGE_DIR=./data/uploads
# Public base URL the API is reachable at (used to build stored-image URLs)
PUBLIC_BASE_URL=http://localhost:3000

# Seed demo plots on boot when the database is empty ("true"/"false")
SEED_ON_BOOT=true

# CORS: comma-separated allowed origins for the web app
CORS_ORIGINS=http://localhost:5173

# ---- Web (apps/web) ----
# Base URL of the API the frontend calls
VITE_API_URL=http://localhost:3000
